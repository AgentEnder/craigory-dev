# This env file uses @env-spec - see https://varlock.dev/env-spec for more info
#
# @defaultRequired=false @defaultSensitive=false
# @generateTypes(lang=ts, path=env.d.ts)
# ----------

# GitHub token — migrated from the former plaintext .env into 1Password.
# Resolved at runtime via the 1Password CLI:
#   op://Dev Secrets/craigory-dev-development/GITHUB_TOKEN_
# NOTE: source code references `GITHUB_TOKEN` (no trailing underscore); the
# plaintext .env defined `GITHUB_TOKEN_`. Migrated faithfully — consider
# renaming to GITHUB_TOKEN if the underscore was a typo.
# @sensitive @required
GITHUB_TOKEN_=exec(`op read "op://Dev Secrets/craigory-dev-development/GITHUB_TOKEN_"`)
